<?xml version="1.0" encoding="UTF-8"?>
<kmodule xmlns="http://www.drools.org/xsd/kmodule">

    <!--
    ═══════════════════════════════════════════════════════════════
    KieBase: LOAN
    - Scans only rules under the "rules.loan" package
    - Stateful session (supports insert/update/retract)
    ═══════════════════════════════════════════════════════════════
    -->
    <kbase name="loanBase"
           packages="rules.loan"
           default="false"
           eventProcessingMode="cloud"
           equalsBehavior="equality">

        <!-- Stateful session — caller must call dispose() after use -->
        <ksession name="loanSession"
                  type="stateless"
                  default="false"
                  clockType="realtime"/>
    </kbase>


    <!--
    ═══════════════════════════════════════════════════════════════
    KieBase: DISCOUNT
    - Scans only rules under the "rules.discount" package
    - Stateless session — fire-and-forget, no dispose() needed
    ═══════════════════════════════════════════════════════════════
    -->
    <kbase name="discountBase"
           packages="org.n2n.learning.droolspoclocal.rules.discount"
           default="false">

        <!-- Stateless session — no working memory retained between calls -->
        <ksession name="discountSession"
                  type="stateless"
                  default="false"/>
    </kbase>


    <!--
    ═══════════════════════════════════════════════════════════════
    KieBase: FRAUD (CEP — Complex Event Processing)
    - Uses STREAM mode for temporal/event-ordering rules
    - Pseudo clock for deterministic testing
    ═══════════════════════════════════════════════════════════════
    -->
    <!--<kbase name="fraudBase"
